# ==============================
# GITIGNORE CUSTOM PARA TEMA GIRASALUD
# ==============================

# Ignorar todo por defecto
/*

# Excluir carpeta de tema girasalud (todo lo que contiene el theme)
!/wp-content/themes/tema-girasalud/
!/wp-content/themes/tema-girasalud/**

# Excluir lo que no debe versionarse (filtros dentro de tema)
/wp-content/themes/tema-girasalud/node_modules/
/wp-content/themes/tema-girasalud/*.log
/wp-content/themes/tema-girasalud/.env
/wp-content/themes/tema-girasalud/.DS_Store
/wp-content/themes/tema-girasalud/Thumbs.db
/wp-content/themes/tema-girasalud/nbproject/private/

# Mantener archivos de configuración del entorno no versionados
/.env
/.vscode/
/.idea/

# Ignorar archivos de WP core y subida de media fuera del tema
/wp-admin/
/wp-includes/
wp-config.php
wp-config-sample.php
license.txt
readme.html
wp-content/uploads/

# Archivos temporales comunes
*.tmp
*.bak
*.zip
*.log

